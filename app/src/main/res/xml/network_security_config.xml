<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Kiwoom API: certificate pinning with system CAs only -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">kiwoom.com</domain>
        <pin-set expiration="2027-01-01">
            <!-- Sectigo Public Server Authentication CA EV R36 (intermediate, 2026-03 renewal) -->
            <pin digest="SHA-256">0RfXDfccNqREsDzRXraedr+pPfaWA8fMplHCU30xYlo=</pin>
            <!-- Sectigo Public Server Authentication Root R46 (cross-signed intermediate) -->
            <pin digest="SHA-256">Douxi77vs4G+Ib/BogbTFymEYq0QSFXwSgVCaZcI09Q=</pin>
            <!-- USERTrust RSA Certification Authority (root backup) -->
            <pin digest="SHA-256">x4QzPSC810K5/cMjb05Qm4k3Bw5zBn4lTdO/nEW/Td4=</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
    <!-- KIS API: certificate pinning with system CAs only -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">koreainvestment.com</domain>
        <pin-set expiration="2027-01-01">
            <!-- Sectigo RSA Organization Validation Secure Server CA (intermediate) -->
            <pin digest="SHA-256">RkhWTcfJAQN/YxOR12VkPo+PhmIoSfWd/JVkg44einY=</pin>
            <!-- USERTrust RSA Certification Authority (root backup) -->
            <pin digest="SHA-256">x4QzPSC810K5/cMjb05Qm4k3Bw5zBn4lTdO/nEW/Td4=</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
