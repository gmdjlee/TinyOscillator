<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/ohlcv_marker_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/tv_marker_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#888888"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_marker_open"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textColor="#333333"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_marker_high"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textColor="#D85A30"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_marker_low"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textColor="#378ADD"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tv_marker_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:textColor="#333333"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_marker_pattern"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FF8F00"
        android:textSize="11sp"
        android:visibility="gone" />

</LinearLayout>
